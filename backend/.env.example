# AfricaZero Backend
# ──────────────────────────────────────────────
# Environment variables — copy to .env and fill in
# ──────────────────────────────────────────────

# DeepSeek API key (for AI origin checking) — get from platform.deepseek.com
DEEPSEEK_API_KEY=sk-...

# Exchange rate API (optional — uses fixed rates if not set)
EXCHANGE_RATE_API_KEY=

# Database — SQLite (local dev) or PostgreSQL (Neon free tier for production)
# Local dev: DATABASE_URL=data/africa_zero.db
# Neon free PostgreSQL: DATABASE_URL=postgres://user:password@host/dbname
# Note: With the static data architecture, only user data (auth, subscriptions)
# is stored in the database. For small scale, SQLite is sufficient.
DATABASE_URL=data/africa_zero.db

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Admin email for error notifications (optional)
ADMIN_EMAIL=hello@africa-zero.com
