# ─────────────────────────────────────────────────────────────────────────────
# AfricaZero Backend — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────────────────────────

# ─── REQUIRED IN PRODUCTION ──────────────────────────────────────────────────

# JWT signing secret. MUST be set in production (min 32 characters recommended).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-production-jwt-secret-here

# ─── OPTIONAL IN PRODUCTION ───────────────────────────────────────────────────

# DeepSeek API key — enables AI-powered origin rule checking and cert document generation.
# Get from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Exchange rate API key — enables live USD/CNY rates (optional, uses fallback 7.25 if not set).
# Free tier at: https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=

# Database URL:
#   Local dev:  DATABASE_URL=data/africa_zero.db
#   Production: DATABASE_URL=postgres://user:password@host:5432/dbname
# For Neon PostgreSQL free tier, get the connection string from your Neon dashboard.
DATABASE_URL=data/africa_zero.db

# CORS allowed origins — comma-separated list of domains.
# In production, only include your actual deployed domains.
CORS_ORIGINS=http://localhost:5173,http://localhost:8000,https://africa.zxqconsulting.com

# Admin notification email
ADMIN_EMAIL=hello@africa-zero.com

# ─── DEVELOPMENT ONLY ────────────────────────────────────────────────────────

# Set to true to enable debug logging and disable secret validation.
# NEVER set to true in production.
DEBUG=false

# Fallback exchange rate when API is unavailable
EXCHANGE_RATE_FALLBACK=7.25
