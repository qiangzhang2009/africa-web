# ─── Track SDK Proxy URL ─────────────────────────────────────────────────────
# Backend proxy for the zxqTrack SDK's geolocation call.
# The SDK calls https://ipapi.co/json/ which blocks browser CORS.
# Set this to your backend base URL so the SDK uses the /geo/ip proxy instead.
# Example (local):  http://localhost:8000
# Example (prod):   https://africa.zxqconsulting.com
# Leave empty in dev — the SDK falls back to direct calls (CORS errors only in prod).
VITE_TRACK_PROXY_URL=

# ─── Cloudflare Worker CORS Proxy URL ────────────────────────────────────────
# After deploying the Cloudflare Worker, set this to your worker URL.
# Example: https://africa-web-cors-proxy.abc123.workers.dev
# Leave empty to use the placeholder URL (will cause CORS errors in production).
VITE_WORKER_URL=https://africa-web-cors-proxy.<your-account>.workers.dev
